# Required: DeepSeek is used for language reasoning and prompt generation.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Required if downloading gated Hugging Face models such as FLUX.1-dev.
HF_TOKEN=hf_your_huggingface_token

# Recommended: keep Hugging Face model caches on a large disk.
HF_HOME=/path/to/hf_cache
HF_HUB_ENABLE_HF_TRANSFER=1

# Optional: only needed when consistency.vision_backend is set to "gemini".
GEMINI_API_KEY=

# Optional: override the local Qwen2-VL checkpoint path used by the VLM gate.
QWEN2VL_MODEL_PATH=

# Optional runtime switches. Leave as 0 for the default CogVideoX pipeline.
FORCE_RIFE=0
FORCE_STILLS=0
OFFLOAD_FLUX=0
